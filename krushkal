#include <iostream>
using namespace std;

int parent[10];

// Find parent
int find(int i) {
    while (parent[i] != i)
        i = parent[i];
    return i;
}

// Union
void unite(int a, int b) {
    parent[a] = b;
}

int main() {
    int n, e;
    int u[10], v[10], w[10];

    cout << "Enter number of vertices: ";
    cin >> n;

    cout << "Enter number of edges: ";
    cin >> e;

    // Input edges
    cout << "Enter u v weight:\n";
    for (int i = 0; i < e; i++) {
        cin >> u[i] >> v[i] >> w[i];
    }

    // Initialize parent
    for (int i = 0; i < n; i++)
        parent[i] = i;

    // Sort edges (simple bubble sort)
    for (int i = 0; i < e - 1; i++) {
        for (int j = 0; j < e - i - 1; j++) {
            if (w[j] > w[j + 1]) {
                swap(w[j], w[j + 1]);
                swap(u[j], u[j + 1]);
                swap(v[j], v[j + 1]);
            }
        }
    }

    cout << "\nEdges in MST:\n";
    int total = 0;

    for (int i = 0; i < e; i++) {
        int a = find(u[i]);
        int b = find(v[i]);

        if (a != b) {
            cout << u[i] << " - " << v[i] << " : " << w[i] << endl;
            total += w[i];
            unite(a, b);
        }
    }

    cout << "Total cost = " << total << endl;

    return 0;
}
