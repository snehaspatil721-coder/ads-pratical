#include <iostream>
using namespace std;

int main() {
    int n, edges;

    cout << "Enter number of cities: ";
    cin >> n;

    string city[10];

    // Input city names
    cout << "Enter city names:\n";
    for (int i = 0; i < n; i++) {
        cin >> city[i];
    }

    int adj[10][10] = {0};

    cout << "Enter number of routes: ";
    cin >> edges;

    // Input routes
    for (int i = 0; i < edges; i++) {
        int u, v;
        cout << "Enter route (city index u v): ";
        cin >> u >> v;

        adj[u][v] = 1;
        adj[v][u] = 1; // undirected graph
    }

    // Display adjacency matrix
    cout << "\nAdjacency Matrix:\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << adj[i][j] << " ";
        }
        cout << endl;
    }

    // Display routes
    cout << "\nRoutes:\n";
    for (int i = 0; i < n; i++) {
        cout << city[i] << " -> ";
        for (int j = 0; j < n; j++) {
            if (adj[i][j] == 1)
                cout << city[j] << " ";
        }
        cout << endl;
    }

    return 0;
}
