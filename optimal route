#include <iostream>
using namespace std;

#define MAX 10
#define INF 9999

int main() {
    int n, graph[MAX][MAX];

    cout << "Enter number of locations: ";
    cin >> n;

    cout << "Enter adjacency matrix (0 if no path):\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> graph[i][j];
            if (graph[i][j] == 0 && i != j)
                graph[i][j] = INF;
        }
    }

    int source, dest;
    cout << "Enter source: ";
    cin >> source;
    cout << "Enter destination: ";
    cin >> dest;

    int dist[MAX], visited[MAX];

    // initialize
    for (int i = 0; i < n; i++) {
        dist[i] = INF;
        visited[i] = 0;
    }

    dist[source] = 0;

    // Dijkstra
    for (int i = 0; i < n - 1; i++) {
        int min = INF, u;

        for (int j = 0; j < n; j++) {
            if (!visited[j] && dist[j] < min) {
                min = dist[j];
                u = j;
            }
        }

        visited[u] = 1;

        for (int v = 0; v < n; v++) {
            if (!visited[v] && graph[u][v] != INF &&
                dist[u] + graph[u][v] < dist[v]) {
                dist[v] = dist[u] + graph[u][v];
            }
        }
    }

    cout << "\nShortest distance from " << source
         << " to " << dest << " = " << dist[dest] << endl;

    return 0;
}
